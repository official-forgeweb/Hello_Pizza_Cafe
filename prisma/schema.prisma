// Use this exact schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id           String     @id @default(uuid())
  name         String
  slug         String     @unique
  description  String?
  imageUrl     String?
  icon         String?
  displayOrder Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  menuItems    MenuItem[]
}

model MenuItem {
  id               String              @id @default(uuid())
  categoryId       String
  category         Category            @relation(fields: [categoryId], references: [id])
  name             String
  slug             String              @unique
  description      String?
  shortDescription String?
  basePrice        Decimal             @db.Decimal(10, 2)
  imageUrl         String?
  thumbnailUrl     String?
  itemType         ItemType            @default(VEG)
  isAvailable      Boolean             @default(true)
  isBestSeller     Boolean             @default(false)
  totalOrders      Int                 @default(0)
  displayOrder     Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  variants         ItemVariant[]
  addOns           MenuItemAddOn[]
  orderItems       OrderItem[]
  featuredItems    FeaturedItem[]
}

enum ItemType {
  VEG
  NON_VEG
}

model ItemVariant {
  id            String    @id @default(uuid())
  menuItemId    String
  menuItem      MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name          String
  variantGroup  String
  priceModifier Decimal   @db.Decimal(10, 2)
  isDefault     Boolean   @default(false)
  isAvailable   Boolean   @default(true)
  displayOrder  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AddOn {
  id           String          @id @default(uuid())
  name         String
  description  String?
  price        Decimal         @db.Decimal(10, 2)
  addonGroup   String
  itemType     ItemType        @default(VEG)
  isAvailable  Boolean         @default(true)
  displayOrder Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  menuItems    MenuItemAddOn[]
}

model MenuItemAddOn {
  id            String   @id @default(uuid())
  menuItemId    String
  menuItem      MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  addOnId       String
  addOn         AddOn    @relation(fields: [addOnId], references: [id], onDelete: Cascade)
  addonGroup    String   @default("Extras")
  variantName   String?
  priceOverride Decimal? @db.Decimal(10, 2)

  @@unique([menuItemId, addOnId, variantName])
}

model Customer {
  name            String
  phone           String       @id
  email           String?
  address         String?
  whatsappOptIn   Boolean      @default(false)
  group           String       @default("new")
  totalOrders     Int          @default(0)
  totalSpent      Decimal      @db.Decimal(10, 2) @default(0)
  lastOrderDate   DateTime?
  lastMessageDate DateTime?
  tags            String[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  orders          Order[]
  messageLogs     MessageLog[]
  loyaltyTransactions LoyaltyTransaction[]

  @@map("customers")
}

model Order {
  id                     String      @id @default(uuid())
  orderNumber            String      @unique
  customerId             String?
  customer               Customer?   @relation(fields: [customerId], references: [phone])
  customerName           String
  customerPhone          String
  customerEmail          String?
  orderType              OrderType   @default(DELIVERY)
  deliveryAddress        String?
  deliveryLat            Decimal?    @db.Decimal(10, 8)
  deliveryLng            Decimal?    @db.Decimal(11, 8)
  deliveryInstructions   String?
  subtotal               Decimal     @db.Decimal(12, 2)
  taxAmount              Decimal     @db.Decimal(10, 2)
  deliveryFee            Decimal     @db.Decimal(10, 2)
  discountAmount         Decimal     @db.Decimal(10, 2)
  totalAmount            Decimal     @db.Decimal(12, 2)
  couponCode             String?
  status                 OrderStatus @default(PENDING)
  orderNotes             String?
  placedAt               DateTime    @default(now())
  confirmedAt            DateTime?
  preparedAt             DateTime?
  deliveredAt            DateTime?
  cancelledAt            DateTime?
  cancellationReason     String?
  estimatedPrepTime      Int?
  estimatedDeliveryTime  Int?
  isSynced               Boolean     @default(false)
  syncedAt               DateTime?
  waConfirmationSent     Boolean     @default(false)
  waPreparingSent        Boolean     @default(false)
  waOutForDeliverySent   Boolean     @default(false)
  waDeliveredSent        Boolean     @default(false)
  loyaltyPointsEarned    Int         @default(0)
  loyaltyPointsRedeemed  Int         @default(0)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  assignedStaffId        String?
  assignedStaff          Staff?      @relation(fields: [assignedStaffId], references: [id])
  items                  OrderItem[]
  messageLogs            MessageLog[]
}

enum OrderType {
  DELIVERY
  PICKUP
  DINE_IN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model OrderItem {
  id                   String             @id @default(uuid())
  orderId              String
  order                Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId           String?
  menuItem             MenuItem?          @relation(fields: [menuItemId], references: [id])
  itemName             String
  itemType             ItemType?
  variantName          String?
  basePrice            Decimal            @db.Decimal(10, 2)
  variantPrice         Decimal            @db.Decimal(10, 2)
  addonsPrice          Decimal            @db.Decimal(10, 2)
  quantity             Int                @default(1)
  itemTotal            Decimal            @db.Decimal(10, 2)
  specialInstructions  String?
  createdAt            DateTime           @default(now())
  addOns               OrderItemAddOn[]
}

model OrderItemAddOn {
  id          String    @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addonName   String
  addonPrice  Decimal   @db.Decimal(10, 2)
  quantity    Int       @default(1)
  createdAt   DateTime  @default(now())
}

model Coupon {
  id             String        @id @default(uuid())
  code           String        @unique
  description    String?
  discountType   DiscountType
  discountValue  Decimal       @db.Decimal(10, 2)
  minimumOrder   Decimal       @db.Decimal(10, 2)
  maxDiscount    Decimal?      @db.Decimal(10, 2)
  validFrom      DateTime?
  validUntil     DateTime?
  usageLimit     Int?
  usageCount     Int           @default(0)
  isActive       Boolean       @default(true)
  type             String        @default("STANDARD") // "STANDARD", "BOGO"
  isFirstOrderOnly Boolean       @default(false)
  applicableDays   Int[]         // [0=Sun, 1=Mon, 2=Tue, etc.]
  applicableItems  String[]      // e.g., ["Large"] or item IDs
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model DeliveryZone {
  id           String   @id @default(uuid())
  name         String
  zoneType     ZoneType
  centerLat    Decimal? @db.Decimal(10, 8)
  centerLng    Decimal? @db.Decimal(11, 8)
  radiusKm     Decimal? @db.Decimal(5, 2)
  pincodes     String[]
  deliveryFee  Decimal  @db.Decimal(10, 2)
  minimumOrder Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ZoneType {
  RADIUS
  PINCODE
}

model FeaturedItem {
  id          String    @id @default(uuid())
  menuItemId  String
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  title       String?
  description String?
  imageUrl    String?
  displayDate DateTime  @db.Date
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([displayDate])
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  name         String
  role         String    @default("ADMIN")
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  campaigns    Campaign[]
}

model OtpToken {
  id        String   @id @default(uuid())
  email     String
  otpHash   String
  attempts  Int      @default(0)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, used])
}

model Staff {
  id             String      @id @default(uuid())
  name           String
  phone          String
  email          String?
  role           StaffRole   @default(DELIVERY)
  avatar         String?
  isActive       Boolean     @default(true)
  ordersHandled  Int         @default(0)
  rating         Float       @default(5.0)
  joinedAt       DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  assignedOrders Order[]
}

enum StaffRole {
  DELIVERY
  KITCHEN
  MANAGER
}

model HeroSlide {
  id           String   @id @default(uuid())
  title        String
  description  String?
  imageUrl     String
  tag          String   @default("NEW")
  discount     String?
  linkUrl      String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SplashAd {
  id           String   @id @default(uuid())
  title        String
  subtitle     String?
  code         String?
  linkUrl      String?
  imageUrl     String
  gradient     String   @default("from-orange-600 to-red-600")
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RestaurantSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model WhatsAppTemplate {
  id            String    @id @default(uuid())
  templateName  String    @unique
  category      String    // marketing, utility, authentication
  language      String    @default("en_US")
  status        String    @default("PENDING") // PENDING, APPROVED, REJECTED
  components    Json      // header, body, footer, buttons
  variables     String[]
  metaTemplateId String?
  headerImageUrl String?
  createdAt     DateTime  @default(now())
  approvedAt    DateTime?
  updatedAt     DateTime  @updatedAt
}

model Campaign {
  id              String       @id @default(uuid())
  name            String
  type            String       @default("marketing") // marketing, utility
  templateName    String
  headerImage     String?
  bodyParameters  String[]
  buttonUrl       String?
  targetType      String       // all, group, custom
  targetGroup     String?
  targetCustomers String[]     // Array of customer IDs
  totalRecipients Int          @default(0)
  sent            Int          @default(0)
  delivered       Int          @default(0)
  read            Int          @default(0)
  failed          Int          @default(0)
  bonusPoints     Int          @default(0)
  status          String       @default("draft") // draft, sending, completed, failed
  scheduledAt     DateTime?
  sentAt          DateTime?
  completedAt     DateTime?
  createdById     String?
  createdBy       AdminUser?   @relation(fields: [createdById], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  messageLogs     MessageLog[]
}

model MessageLog {
  id                String    @id @default(uuid())
  campaignId        String?
  campaign          Campaign? @relation(fields: [campaignId], references: [id])
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [phone])
  orderId           String?
  order             Order?    @relation(fields: [orderId], references: [id])
  phone             String
  whatsappMessageId String?   @unique
  messageType       String    // order_confirmation, order_preparing, order_delivered, marketing
  templateUsed      String?
  status            String    @default("queued") // queued, sent, delivered, read, failed
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  cost              Decimal   @db.Decimal(10, 4) @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model LoyaltySetting {
  id              String   @id @default("default")
  pointsPerAmount Int      @default(5)
  amountThreshold Decimal  @db.Decimal(10, 2) @default(100.00)
  updatedAt       DateTime @updatedAt

  @@map("loyalty_settings")
}

model LoyaltyTransaction {
  id            String   @id @default(uuid())
  phoneNumber   String
  customer      Customer @relation(fields: [phoneNumber], references: [phone], onDelete: Cascade)
  orderId       String?
  billId        String?
  type          String   // EARN, REDEEM, BONUS, EXPIRE
  points        Int
  timestamp     DateTime @default(now())
  expiryDate    DateTime
  isPending     Boolean  @default(true)
  campaignId    String?

  @@map("loyalty_transactions")
}

model CustomerCampaign {
  id                String   @id @default(uuid())
  campaignName      String
  messageTemplateId String
  targetFilter      String
  status            String   @default("draft")
  createdAt         DateTime @default(now())
}

model Device {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceName String   @map("device_name")
  deviceIp   String?  @map("device_ip")
  lastSeenAt DateTime @default(now()) @map("last_seen_at") @db.Timestamptz
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  syncQueues CloudSyncQueue[]
  dbBackups  DbBackup[]

  @@map("devices")
}

model GlobalSetting {
  id                     Int      @id @default(1)
  cafeName               String   @map("cafe_name")
  taxPercent             Decimal  @default(5.0) @map("tax_percent") @db.Decimal(5, 2)
  currency               String   @default("INR")
  loyaltyPointsPerAmount Decimal  @default(5) @map("loyalty_points_per_amount") @db.Decimal(10, 2)
  loyaltyAmountThreshold Decimal  @default(100) @map("loyalty_amount_threshold") @db.Decimal(10, 2)
  loyaltyMinHours        Decimal  @default(24) @map("loyalty_min_hours") @db.Decimal(10, 2)
  loyaltyMaxDays         Decimal  @default(30) @map("loyalty_max_days") @db.Decimal(10, 2)
  updatedAt              DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("global_settings")
}

model CloudMenuItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  category    String
  price       Decimal  @db.Decimal(10, 2)
  isAvailable Boolean  @default(true) @map("is_available")
  imageUrl    String?  @map("image_url")
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz
  deleted     Boolean  @default(false)

  @@map("menu_items")
}

model CloudDiscountRule {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  type            String    // "percentage" | "flat"
  value           Decimal   @db.Decimal(10, 2)
  minOrderAmount  Decimal   @default(0) @map("min_order_amount") @db.Decimal(10, 2)
  applicableItems String[]  @default([]) @map("applicable_items")
  isActive        Boolean   @default(true) @map("is_active")
  validFrom       DateTime? @map("valid_from") @db.Timestamptz
  validUntil      DateTime? @map("valid_until") @db.Timestamptz
  applicableDays  Int[]     @default([]) @map("applicable_days")
  startTime       String?   @map("start_time")
  endTime         String?   @map("end_time")
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@map("discount_rules")
}

model CloudEmailConfig {
  id                    Int      @id @default(1)
  smtpHost              String?  @map("smtp_host")
  smtpPort              Int?     @default(587) @map("smtp_port")
  smtpUser              String?  @map("smtp_user")
  smtpPass              String?  @map("smtp_pass")
  salesReportRecipients String[] @default([]) @map("sales_report_recipients")
  hourlyReportEnabled   Boolean  @default(true) @map("hourly_report_enabled")
  updatedAt             DateTime @default(now()) @map("updated_at") @db.Timestamptz

  @@map("email_config")
}

model CloudSyncQueue {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId   String?   @map("device_id") @db.Uuid
  device     Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  tableName  String    @map("table_name")
  recordId   String    @map("record_id")
  operation  String
  payload    Json
  status     String    @default("pending")
  retryCount Int       @default(0) @map("retry_count")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  syncedAt   DateTime? @map("synced_at") @db.Timestamptz

  @@map("sync_queue")
}

model DbBackup {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fileName        String   @map("file_name")
  storagePath     String   @map("storage_path")
  fileSize        BigInt   @map("file_size")
  createdByDevice String?  @map("created_by_device") @db.Uuid
  device          Device?  @relation(fields: [createdByDevice], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("db_backups")
}

