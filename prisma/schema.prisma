// Use this exact schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id           String     @id @default(uuid())
  name         String
  slug         String     @unique
  description  String?
  imageUrl     String?
  icon         String?
  displayOrder Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  menuItems    MenuItem[]
}

model MenuItem {
  id               String              @id @default(uuid())
  categoryId       String
  category         Category            @relation(fields: [categoryId], references: [id])
  name             String
  slug             String              @unique
  description      String?
  shortDescription String?
  basePrice        Decimal             @db.Decimal(10, 2)
  imageUrl         String?
  thumbnailUrl     String?
  itemType         ItemType            @default(VEG)
  isAvailable      Boolean             @default(true)
  isBestSeller     Boolean             @default(false)
  totalOrders      Int                 @default(0)
  displayOrder     Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  variants         ItemVariant[]
  addOns           MenuItemAddOn[]
  orderItems       OrderItem[]
  featuredItems    FeaturedItem[]
}

enum ItemType {
  VEG
  NON_VEG
}

model ItemVariant {
  id            String    @id @default(uuid())
  menuItemId    String
  menuItem      MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  name          String
  variantGroup  String
  priceModifier Decimal   @db.Decimal(10, 2)
  isDefault     Boolean   @default(false)
  isAvailable   Boolean   @default(true)
  displayOrder  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AddOn {
  id           String          @id @default(uuid())
  name         String
  description  String?
  price        Decimal         @db.Decimal(10, 2)
  addonGroup   String
  itemType     ItemType        @default(VEG)
  isAvailable  Boolean         @default(true)
  displayOrder Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  menuItems    MenuItemAddOn[]
}

model MenuItemAddOn {
  id          String   @id @default(uuid())
  menuItemId  String
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  addOnId     String
  addOn       AddOn    @relation(fields: [addOnId], references: [id], onDelete: Cascade)
  addonGroup  String   @default("Extras")
  variantName String?

  @@unique([menuItemId, addOnId, variantName])
}

model Customer {
  id              String       @id @default(uuid())
  name            String
  phone           String       @unique
  email           String?
  address         String?
  whatsappOptIn   Boolean      @default(false)
  group           String       @default("new")
  totalOrders     Int          @default(0)
  totalSpent      Decimal      @db.Decimal(10, 2) @default(0)
  lastOrderDate   DateTime?
  lastMessageDate DateTime?
  tags            String[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  orders          Order[]
  messageLogs     MessageLog[]
}

model Order {
  id                     String      @id @default(uuid())
  orderNumber            String      @unique
  customerId             String?
  customer               Customer?   @relation(fields: [customerId], references: [id])
  customerName           String
  customerPhone          String
  customerEmail          String?
  orderType              OrderType   @default(DELIVERY)
  deliveryAddress        String?
  deliveryLat            Decimal?    @db.Decimal(10, 8)
  deliveryLng            Decimal?    @db.Decimal(11, 8)
  deliveryInstructions   String?
  subtotal               Decimal     @db.Decimal(12, 2)
  taxAmount              Decimal     @db.Decimal(10, 2)
  deliveryFee            Decimal     @db.Decimal(10, 2)
  discountAmount         Decimal     @db.Decimal(10, 2)
  totalAmount            Decimal     @db.Decimal(12, 2)
  couponCode             String?
  status                 OrderStatus @default(PENDING)
  orderNotes             String?
  placedAt               DateTime    @default(now())
  confirmedAt            DateTime?
  preparedAt             DateTime?
  deliveredAt            DateTime?
  cancelledAt            DateTime?
  cancellationReason     String?
  estimatedPrepTime      Int?
  estimatedDeliveryTime  Int?
  isSynced               Boolean     @default(false)
  syncedAt               DateTime?
  waConfirmationSent     Boolean     @default(false)
  waPreparingSent        Boolean     @default(false)
  waOutForDeliverySent   Boolean     @default(false)
  waDeliveredSent        Boolean     @default(false)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  assignedStaffId        String?
  assignedStaff          Staff?      @relation(fields: [assignedStaffId], references: [id])
  items                  OrderItem[]
  messageLogs            MessageLog[]
}

enum OrderType {
  DELIVERY
  PICKUP
  DINE_IN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model OrderItem {
  id                   String             @id @default(uuid())
  orderId              String
  order                Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId           String?
  menuItem             MenuItem?          @relation(fields: [menuItemId], references: [id])
  itemName             String
  itemType             ItemType?
  variantName          String?
  basePrice            Decimal            @db.Decimal(10, 2)
  variantPrice         Decimal            @db.Decimal(10, 2)
  addonsPrice          Decimal            @db.Decimal(10, 2)
  quantity             Int                @default(1)
  itemTotal            Decimal            @db.Decimal(10, 2)
  specialInstructions  String?
  createdAt            DateTime           @default(now())
  addOns               OrderItemAddOn[]
}

model OrderItemAddOn {
  id          String    @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addonName   String
  addonPrice  Decimal   @db.Decimal(10, 2)
  quantity    Int       @default(1)
  createdAt   DateTime  @default(now())
}

model Coupon {
  id             String        @id @default(uuid())
  code           String        @unique
  description    String?
  discountType   DiscountType
  discountValue  Decimal       @db.Decimal(10, 2)
  minimumOrder   Decimal       @db.Decimal(10, 2)
  maxDiscount    Decimal?      @db.Decimal(10, 2)
  validFrom      DateTime?
  validUntil     DateTime?
  usageLimit     Int?
  usageCount     Int           @default(0)
  isActive       Boolean       @default(true)
  type             String        @default("STANDARD") // "STANDARD", "BOGO"
  isFirstOrderOnly Boolean       @default(false)
  applicableDays   Int[]         // [0=Sun, 1=Mon, 2=Tue, etc.]
  applicableItems  String[]      // e.g., ["Large"] or item IDs
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model DeliveryZone {
  id           String   @id @default(uuid())
  name         String
  zoneType     ZoneType
  centerLat    Decimal? @db.Decimal(10, 8)
  centerLng    Decimal? @db.Decimal(11, 8)
  radiusKm     Decimal? @db.Decimal(5, 2)
  pincodes     String[]
  deliveryFee  Decimal  @db.Decimal(10, 2)
  minimumOrder Decimal  @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ZoneType {
  RADIUS
  PINCODE
}

model FeaturedItem {
  id          String    @id @default(uuid())
  menuItemId  String
  menuItem    MenuItem  @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  title       String?
  description String?
  imageUrl    String?
  displayDate DateTime  @db.Date
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([displayDate])
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  name         String
  role         String    @default("ADMIN")
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  campaigns    Campaign[]
}

model OtpToken {
  id        String   @id @default(uuid())
  email     String
  otpHash   String
  attempts  Int      @default(0)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, used])
}

model Staff {
  id             String      @id @default(uuid())
  name           String
  phone          String
  email          String?
  role           StaffRole   @default(DELIVERY)
  avatar         String?
  isActive       Boolean     @default(true)
  ordersHandled  Int         @default(0)
  rating         Float       @default(5.0)
  joinedAt       DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  assignedOrders Order[]
}

enum StaffRole {
  DELIVERY
  KITCHEN
  MANAGER
}

model HeroSlide {
  id           String   @id @default(uuid())
  title        String
  description  String?
  imageUrl     String
  tag          String   @default("NEW")
  discount     String?
  linkUrl      String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SplashAd {
  id           String   @id @default(uuid())
  title        String
  subtitle     String?
  code         String?
  linkUrl      String?
  imageUrl     String
  gradient     String   @default("from-orange-600 to-red-600")
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RestaurantSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model WhatsAppTemplate {
  id            String    @id @default(uuid())
  templateName  String    @unique
  category      String    // marketing, utility, authentication
  language      String    @default("en_US")
  status        String    @default("PENDING") // PENDING, APPROVED, REJECTED
  components    Json      // header, body, footer, buttons
  variables     String[]
  metaTemplateId String?
  createdAt     DateTime  @default(now())
  approvedAt    DateTime?
  updatedAt     DateTime  @updatedAt
}

model Campaign {
  id              String       @id @default(uuid())
  name            String
  type            String       @default("marketing") // marketing, utility
  templateName    String
  headerImage     String?
  bodyParameters  String[]
  buttonUrl       String?
  targetType      String       // all, group, custom
  targetGroup     String?
  targetCustomers String[]     // Array of customer IDs
  totalRecipients Int          @default(0)
  sent            Int          @default(0)
  delivered       Int          @default(0)
  read            Int          @default(0)
  failed          Int          @default(0)
  status          String       @default("draft") // draft, sending, completed, failed
  scheduledAt     DateTime?
  sentAt          DateTime?
  completedAt     DateTime?
  createdById     String?
  createdBy       AdminUser?   @relation(fields: [createdById], references: [id])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  messageLogs     MessageLog[]
}

model MessageLog {
  id                String    @id @default(uuid())
  campaignId        String?
  campaign          Campaign? @relation(fields: [campaignId], references: [id])
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  orderId           String?
  order             Order?    @relation(fields: [orderId], references: [id])
  phone             String
  whatsappMessageId String?   @unique
  messageType       String    // order_confirmation, order_preparing, order_delivered, marketing
  templateUsed      String?
  status            String    @default("queued") // queued, sent, delivered, read, failed
  errorMessage      String?
  sentAt            DateTime?
  deliveredAt       DateTime?
  readAt            DateTime?
  cost              Decimal   @db.Decimal(10, 4) @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
